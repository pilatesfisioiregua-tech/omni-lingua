{
  "manifest_version": 3,
  "name": "Omni-Lingua Subtitle Companion",
  "description": "Marca palabras i+1 en subtítulos de Netflix/YouTube · sentence mining one-click",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Omni-Lingua",
    "default_popup": "src/popup.html"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.netflix.com/*",
    "https://www.youtube.com/*",
    "https://www.disneyplus.com/*",
    "https://app.tv.apple.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.netflix.com/*",
        "https://www.youtube.com/*"
      ],
      "js": ["src/content.js"],
      "css": ["src/overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
