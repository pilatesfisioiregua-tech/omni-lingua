# Omni-Lingua · environment variables · todas opcionales · modo demo si faltan
# Copia este archivo a .env.local y rellena las que quieras activar.

# Anthropic API · Coach + Conversation + Daily Story + Mirror + Writing correction
ANTHROPIC_API_KEY=

# ACRCloud · identificación canciones/podcasts (Phase 4.5)
ACRCLOUD_HOST=
ACRCLOUD_KEY=
ACRCLOUD_SECRET=

# Modal GPU endpoints · Whisper transcription + GOP pronunciation (opcionales)
MODAL_TRANSCRIBE_ENDPOINT=
MODAL_GOP_ENDPOINT=

# AssemblyAI · diarización speakers (opcional)
ASSEMBLY_API_KEY=
